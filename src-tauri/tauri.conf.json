{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PoPManager",
  "version": "1.0.1",
  "identifier": "com.proofofprints.popmanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PoPManager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/proofofprints/PoPManager/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2N0MzODRGQUE5QzhFMDQKUldRRWpweXFUemg4OWlOMGdxeUZ0cmxqbWMremUrTnI2ZlRsbCtWR1I3LzdCckJBUFZHZGN0UTAK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Proof of Prints",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "bannerPath": "icons/msi-banner.bmp",
        "dialogImagePath": "icons/msi-dialog.bmp"
      }
    }
  }
}
