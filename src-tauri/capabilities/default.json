{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default",
    "shell:allow-open",
    "notification:default",
    "updater:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-app-write-recursive"
  ]
}
